# Environment and secret files
.env.production
.env.local
.env

# SSL certificates (never commit these!)
config/ssl/*.pem
config/ssl/*.key
config/ssl/*.crt

# Keep the ssl directory structure
!config/ssl/.gitkeep

# Logs and temp files
*.log
logs/
tmp/
.cache/

# Backups (never commit database backups!)
backups/*.sql
backups/*.sql.gz

# Keep backup directory structure
!backups/.gitkeep

# IDE and editor settings
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Development files (you removed these)
docker-compose.override.yml
Dockerfile.dev

# Go build artifacts
tmp/
main
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Firebase credentials (never commit!)
firebase-adminsdk.json
*-firebase-adminsdk-*.json

# Go workspace files
go.work
go.work.sum

# Test coverage
coverage.txt
coverage.out
*.coverprofile