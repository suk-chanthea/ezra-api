# ===========================================
# Ezra API - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to git (it's in .gitignore)

# ===========================================
# Nginx Settings
# ===========================================
NGINX_HTTP_PORT=8088
NGINX_HTTPs_PORT=443

# ===========================================
# Application Settings
# ===========================================
APP_NAME=Ezra API
APP_VERSION=1.0.0
APP_ENV=production
APP_PORT=8090
APP_DEBUG=false

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
# REQUIRED: Database password must be set
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=ezradb
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# Alternative: Use connection URL format (comment out individual DB_* vars above if using this)
# POSTGRES_URL=postgres://postgres:YourSecurePasswordHere123!@localhost:5432/ezradb?sslmode=disable

# ===========================================
# JWT Authentication
# ===========================================
# REQUIRED: Secret key must be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET="EZRA@christian_event*secret#6677"

# Token expiry durations
JWT_TOKEN_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# ===========================================
# Redis Cache (Optional)
# ===========================================
# Enable if using redis profile with docker-compose --profile full
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD="EZRA@redis#6677"
REDIS_DB=0

# ===========================================
# Google OAuth (Optional)
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ===========================================
# Firebase Cloud Messaging (Optional)
# ===========================================
# For push notifications
# Get from: https://console.firebase.google.com/
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# ===========================================
# Email / SMTP Configuration (Optional)
# ===========================================
# For OTP and notifications
EMAIL_ENABLED=true
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USERNAME=development@komplech.com
SMTP_PASSWORD=G7x!pQ2vLm
SMTP_FROM=ezra@komplech.com
SMTP_SECURE=ssl

# OTP Settings
OTP_EXPIRY_MINUTES=10

# ===========================================
# PayWay Payment Gateway (Optional)
# ===========================================
# For donation/payment processing
# Get from: https://www.payway.com.kh/
PAYWAY_ENABLED=false
PAYWAY_MERCHANT_ID=ec462404
PAYWAY_API_KEY=369b16570f6914c0d538b64e4b7c656ca195b00f
PAYWAY_API_USERNAME="Suk Chanthea"
PAYWAY_BASE_URL=https://api-sandbox.payway.com.kh
PAYWAY_RETURN_URL=http://localhost:3000/donation/complete
PAYWAY_CONTINUE_URL=http://localhost:3000/donation/success
PAYWAY_CALLBACK_URL=http://localhost:8080/webhooks/payway

# ===========================================
# Gin Framework Settings
# ===========================================
# Mode: debug, release, or test
GIN_MODE=release