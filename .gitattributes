# Git attributes for better handling of line endings and diffs

# Auto detect text files and perform LF normalization
* text=auto

# Go source files
*.go text eol=lf

# Shell scripts
*.sh text eol=lf

# SQL files
*.sql text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Markdown files
*.md text eol=lf

# JSON files
*.json text eol=lf

# Environment files
.env* text eol=lf

# Docker files
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

